# ==========================================
# Byone Arena - Environment Configuration
# ==========================================
# Copy file ini menjadi .env dan sesuaikan nilainya

# ==========================================
# Application
# ==========================================
APP_NAME=Byone Arena
APP_ENV=development       # development | production
PORT=8080
LOG_LEVEL=info            # debug | info | warn | error

# ==========================================
# Database PostgreSQL
# ==========================================
DB_HOST=postgres         # Ganti 'postgres' jika menggunakan Docker
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=.|W.zExVV%lE  # Ganti dengan password yang aman!
DB_NAME=byone_arena
DB_SSLMODE=disable        # disable | require | verify-full

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=ganti-dengan-secret-key-yang-sangat-panjang-dan-aman-min-32-chars
JWT_EXPIRE_HOURS=24

# ==========================================
# pgAdmin (opsional, hanya untuk development)
# ==========================================
PGADMIN_EMAIL=admin@byone.local
PGADMIN_PASSWORD=admin123
